# pnpm settings
auto-install-peers=true
auto-include-optional-root=false
engine-strict=true
resolution-mode=highest
save-exact=true
strict-peer-dependencies=false

# Registry
registry=https://registry.npmjs.org/

# Shims for corepack (pnpm ships as a standalone binary)
# Do not add pnpm binary shim to PATH in CI
enable-pre-post-scripts=false
