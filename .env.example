# InterviewPilot AI — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env or .env.local to version control.

# ===================
# Application
# ===================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===================
# Database (Supabase PostgreSQL)
# ===================
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/interviewpilot



# ===================
# REDIS (FOR CACHEING)
# ===================
REDIS_URL=


# ===================
# Authentication
# ===================
JWT_SECRET=                                                  # Min 32 chars, used for access token signing
JWT_REFRESH_SECRET=                                          # Min 32 chars, used for refresh token signing

# ===================
# AI / OpenAI
# ===================
OPENAI_API_KEY=sk-                                          # OpenAI API key
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview              # Realtime model identifier

# ===================
# Voice AI / ElevenLabs
# ===================
ELEVENLABS_API_KEY=                                         # ElevenLabs API key
ELEVENLABS_AGENT_ID=                                        # ConvAI agent ID (create at elevenlabs.io/app/conversational-ai)

# ===================
# Voice Provider Selection
# ===================
VOICE_PROVIDER=elevenlabs                                   # Primary: elevenlabs | openai | mock
VOICE_FALLBACK_PROVIDER=mock                                # Fallback if primary fails

# ===================
# Optional: Observability
# ===================
# LOG_LEVEL=info                                             # debug | info | warn | error
# SENTRY_DSN=                                               # Sentry DSN (only in production)
ELEVENLABS_BACKUP_API_KEY=                                    # Backup ElevenLabs API key
ELEVENLABS_BACKUP_AGENT_ID=                                   # Backup ConvAI agent ID



  ELEVENLABS_EXTRA_API_KEY=
  ELEVENLABS_EXTRA_AGENT_ID=
