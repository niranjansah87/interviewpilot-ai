# InterviewPilot AI — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env or .env.local to version control.

# ===================
# Application
# ===================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===================
# Database (Supabase PostgreSQL)
# ===================
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/interviewpilot

# ===================
# Authentication
# ===================
JWT_SECRET=                                                  # Min 32 chars, used for access token signing
JWT_REFRESH_SECRET=                                          # Min 32 chars, used for refresh token signing

# ===================
# AI / OpenAI
# ===================
OPENAI_API_KEY=sk-                                          # OpenAI API key
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview              # Realtime model identifier

# ===================
# Optional: Observability
# ===================
# LOG_LEVEL=info                                             # debug | info | warn | error
# SENTRY_DSN=                                               # Sentry DSN (only in production)
