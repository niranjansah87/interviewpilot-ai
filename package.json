    "db:health": "tsx scripts/healthcheck.ts",
    "cleanup": "tsx scripts/cleanup.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
